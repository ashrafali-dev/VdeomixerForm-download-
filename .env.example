# ── Required ──────────────────────────────────────────────
PORT=3000

# ── Kuaishou ──────────────────────────────────────────────
# Paste browser cookie string from kuaishou.com
KS_COOKIES=kpf=PC_WEB; clientid=3; did=web_xxx...

# ── Proxy / Tunnel ────────────────────────────────────────
YTDLP_PROXY=socks5://127.0.0.1:1080
VMESS_LINK=vmess://eyJ...

# ── Google OAuth (YouTube + Drive upload) ─────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/google/callback

# ── Paths (Railway defaults, don't change) ────────────────
TEMP_DIR=/tmp/vmixer
OUTPUT_DIR=/app/data/output
COOKIES_FILE=/app/data/cookies/cookies.txt
CONFIG_FILE=/app/data/config.json
